# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://aptenbyte.com
CSRF_TRUSTED_ORIGINS=https://api.aptenbyte.com

# Database (Neon Postgres pooled URL; leave blank to use local SQLite)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Google sign-in (Web OAuth client ID the app's ID token is issued for)
GOOGLE_OAUTH_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com

# AI proxy
OPENROUTER_API_KEY=your_openrouter_api_key

# Email (Brevo SMTP; leave blank to print emails to the console)
EMAIL_HOST_USER=your_login@smtp-brevo.com
EMAIL_HOST_PASSWORD=your_brevo_smtp_key
DEFAULT_FROM_EMAIL=AptenByte <no-reply@aptenbyte.com>
