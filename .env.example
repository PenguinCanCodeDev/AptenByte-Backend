# --- Gemini API keys (Google AI Studio) ---
# Get them at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY_1=your_first_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here

# --- OpenRouter API keys ---
# Get them at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_KEY_2=your_second_openrouter_api_key_here

# --- Optional AI model overrides ---
# GEMINI_MODEL=gemini-2.0-flash
# OPENROUTER_MODELS=meta-llama/llama-3.3-70b-instruct:free,openai/gpt-oss-120b:free

# --- Google sign-in ---
# Comma-separated OAuth client IDs the app signs in with (Android / iOS / web).
# A Google ID token is accepted only if its "aud" matches one of these.
# GOOGLE_OAUTH_CLIENT_IDS=1234-abc.apps.googleusercontent.com,5678-def.apps.googleusercontent.com

# --- Email (Brevo SMTP) ---
# From Brevo dashboard > SMTP & API > SMTP. Leave unset in dev to print emails to the console.
# EMAIL_HOST_USER is your Brevo SMTP login (e.g. 8xxxxx001@smtp-brevo.com).
# EMAIL_HOST_PASSWORD is a generated Brevo SMTP key (NOT your account password).
# EMAIL_HOST_USER=xxxxxx@smtp-brevo.com
# EMAIL_HOST_PASSWORD=your_brevo_smtp_key
# DEFAULT_FROM_EMAIL must be a sender verified in Brevo.
# DEFAULT_FROM_EMAIL=AptenByte <no-reply@aptenbyte.com>

# --- Django ---
# Generate a new one for production: python -c "import secrets;print(secrets.token_urlsafe(50))"
# DJANGO_SECRET_KEY=change-me-in-production
# DJANGO_DEBUG=True
# Comma-separated hostnames allowed to serve the API (required when DEBUG=False).
# DJANGO_ALLOWED_HOSTS=proxy.penguinscancode.com,penguinscancode.com
# Comma-separated website origins allowed to call the API from a browser (the marketing site).
# DJANGO_DEBUG=True allows any origin; in production set this to your site.
# CORS_ALLOWED_ORIGINS=https://aptenbyte.com,https://www.aptenbyte.com
# Scheme-qualified origins trusted for admin/CSRF POSTs (needed for admin login when DEBUG=False).
# CSRF_TRUSTED_ORIGINS=https://aptenbyte-api.onrender.com

# --- Database ---
# When DATABASE_URL is set, Django uses it (e.g. Neon Postgres). When unset, it uses local SQLite.
# Use Neon's POOLED connection string (host contains "-pooler"); keep ?sslmode=require.
# DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# Path to the SQLite file for local dev (ignored when DATABASE_URL is set).
# SQLITE_PATH=/data/db.sqlite3
