# AptenByte backend env. Active KEY=value lines are ones you set; lines that
# start with "#" are OPTIONAL overrides (the code has a sensible default).

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# Set DJANGO_DEBUG=False in production (Render).
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://aptenbyte.vercel.app
CSRF_TRUSTED_ORIGINS=https://aptenbyte.vercel.app

# ── Database ──────────────────────────────────────────────────────────────────
# Neon Postgres pooled URL. Leave blank to use local SQLite.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# Path for the local SQLite file when DATABASE_URL is blank.
# SQLITE_PATH=db.sqlite3

# ── Google sign-in (built-in AI) ──────────────────────────────────────────────
# The Web OAuth client id(s) the app's Google ID token is issued for (comma-separated).
GOOGLE_OAUTH_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com

# ── AI proxy ──────────────────────────────────────────────────────────────────
# Server holds the keys so users get AI without their own. Providers are tried in
# an adaptive order (a failed one is demoted for the next request). Set at least
# one provider. The _2 keys are optional extra keys for failover.
GEMINI_API_KEY_1=your_gemini_api_key
# GEMINI_API_KEY_2=your_second_gemini_key
OPENROUTER_API_KEY=your_openrouter_api_key
# OPENROUTER_API_KEY_2=your_second_openrouter_key
NVIDIA_API_KEY=your_nvidia_nvapi_key
# NVIDIA_API_KEY_1 and NVIDIA_API_KEY_2 are also accepted.
# Model overrides (optional — sensible free-tier defaults are built in):
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-flash-latest
# OPENROUTER_MODELS=openrouter/free,openai/gpt-oss-120b:free,openai/gpt-oss-20b:free
# NVIDIA_MODELS=meta/llama-3.3-70b-instruct,nvidia/llama-3.1-nemotron-70b-instruct

# ── Admin dashboard (/dashboard + /api/stats/) ────────────────────────────────
# Token that gates the private stats dashboard (sent as a Bearer header).
# Leave blank/unset to disable the dashboard entirely.
ADMIN_STATS_TOKEN=change-me-to-a-long-random-string
# GitHub repo whose release download_count feeds the "downloads" stat.
# RELEASES_REPO=PenguinCanCodeDev/aptenbyte-releases
# Optional GitHub token to lift the API rate limit (60/hr -> 5000/hr).
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# ── Email (Brevo SMTP; leave USER/PASSWORD blank to print emails to the console) ──
EMAIL_HOST_USER=your_login@smtp-brevo.com
EMAIL_HOST_PASSWORD=your_brevo_smtp_key
DEFAULT_FROM_EMAIL=AptenByte <no-reply@aptenbyte.com>
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
